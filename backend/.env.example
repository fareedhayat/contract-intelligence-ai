# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Cosmos DB
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=contract-intelligence

# Azure AI Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com
DOC_INTELLIGENCE_KEY=your-key

# Azure Blob Storage
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
BLOB_CONTAINER_NAME=contracts

# Local development fallbacks
USE_LOCAL_STORAGE=true
USE_LOCAL_PARSER=true

# CUAD dataset path (relative to backend/)
CUAD_DATA_PATH=data
